{% block _entry_line_notification_flg_row %}
    {% if form|length > 0 %}
        <div>
        <dl>
            <dt>
            {{ form_label(form, 'LINE通知', {'label_attr': {'class': 'ec-label'}}) }}
            </dt>
            <dd>
                {% if form.vars.value == 1 %}
                    受け取る
                {% elseif form.vars.value == 0 %}
                    受け取らない
                {% endif %}
                {{ form_widget(form, { type: 'hidden'}) }}
            </dd>
        </dl>
        </div>
    {% endif %}
{% endblock _entry_line_notification_flg_row %}
