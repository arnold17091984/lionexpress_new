<div id="customer_rank" style="display:none;">
    <div class="row mb-2">
        <div class="col-3">
            <span>{{ form.children.CustomerRank.vars.label }}</span>
        </div>
        <div class="col">
            {{ form_widget(form.CustomerRank) }}
            {{ form_errors(form.CustomerRank) }}
        </div>
    </div>
</div>

<div id="customer_rank_info" style="display:none">
    {% if Customer.id and CustomerCondition %}
        <div class="card rounded border-0 mb-4">
            <div class="card-header">
                <div class="row">
                    <div class="col-8">
                        <div class="d-inline-block">
                        <span class="card-title">
                            {{ 'customerrank.admin.customer.rank_condition'|trans }}
                        </span>
                        </div>
                    </div>
                    <div class="col-4 text-right">
                        <a data-toggle="collapse" href="#rankInfo" aria-expanded="false"
                            aria-controls="rankInfo">
                            <i class="fa fa-angle-up fa-lg"></i>
                        </a>
                    </div>
                </div>
            </div>
            <div class="collapse show ec-cardCollapse" id="rankInfo">
                <div class="card-body">
                    <div class="row mb-2">
                        <div class="col-3">
                            <div class="d-inline-block" >
                                <span>{{ 'customerrank.admin.rank.edit.label.cond_amount'|trans }}</span>
                            </div>
                        </div>
                        <div class="col">
                            <p>{{ CustomerCondition.total_amount|price }}</p>
                        </div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-3">
                            <div class="d-inline-block" >
                                <span>{{ 'customerrank.admin.rank.edit.label.cond_buytimes'|trans }}</span>
                            </div>
                        </div>
                        <div class="col">
                            <p>{{ CustomerCondition.total_buytimes }}</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    {% endif %}
</div>