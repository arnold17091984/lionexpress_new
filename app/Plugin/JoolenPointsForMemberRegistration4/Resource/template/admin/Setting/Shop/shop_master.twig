{% block javascript %}
    <script>
        $(function () {
            const joolen_member_registration_point_forms = $('#joolen-member-registration-point-forms');
            $('#ex-shop-point').parent().parent().append(joolen_member_registration_point_forms);
            joolen_member_registration_point_forms.removeClass('d-none');
        });
    </script>
{% endblock %}

{% block stylesheet %}
    <style>
        #shop_master_joolen_points_for_member_registration4_range_datetime_apply_datetime_start.form-inline,
        #shop_master_joolen_points_for_member_registration4_range_datetime_apply_datetime_end.form-inline{
            height: 33px!important;
        }
    </style>
{% endblock %}

{% block main %}
    <div id="joolen-member-registration-point-forms" class="card rounded border-0 mb-4  d-none">
        <div class="card-header">
            <span>{{ 'joolenpointsformemberregistration4.admin.setting.shop.option_member_registration_point'|trans }}</span>
        </div>
        <div id="member-registration-point" class="card-body">

            {# ポイント（常時付与設定） #}
            {% set joolen_always_member_registration_point = form.joolen_always_member_registration_point %}
            <div class="row">
                <div class="col-3">
                    <div class="d-inline-block">
                        <div
                                class="d-inline-block"
                                data-tooltip="true"
                                data-html="true"
                                data-placement="top"
                                title="{{ 'joolenpointsformemberregistration4.admin.setting.shop.joolen_always_member_registration_point.help'|trans|raw|nl2br }}"
                        >
                            <span>{{ 'joolenpointsformemberregistration4.admin.setting.shop.joolen_always_member_registration_point'|trans }}</span>
                            <i class="fa fa-question-circle fa-lg ml-1"></i>
                        </div>
                    </div>
                </div>
                <div class="col mb-2">
                    <div class="input-group col-2 pl-0">
                        <div class="input-group">
                            {{ form_widget(joolen_always_member_registration_point) }}
                        </div>
                    </div>
                    {{ form_errors(joolen_always_member_registration_point) }}
                </div>
            </div>

            {# ポイント（期間中のみ付与設定）、開始日〜終了日（期間中のみ付与設定） #}
            {% set joolen_member_registration_point_during_period = form.member_registration_point %}
            {% set joolen_member_registration_point_period_start = form.joolen_points_for_member_registration4_range_datetime.apply_datetime_start %}
            {% set joolen_member_registration_point_period_end = form.joolen_points_for_member_registration4_range_datetime.apply_datetime_end %}
            <div class="row">
                <div class="col-3">
                    <div class="d-inline-block">
                        <div
                                class="d-inline-block"
                                data-tooltip="true"
                                data-html="true"
                                data-placement="top"
                                title="{{ 'joolenpointsformemberregistration4.admin.setting.shop.member_registration_point.help'|trans|raw|nl2br }}"
                        >
                            <span>{{ 'joolenpointsformemberregistration4.admin.setting.shop.member_registration_point'|trans }}</span>
                            <i class="fa fa-question-circle fa-lg ml-1"></i>
                        </div>
                    </div>
                </div>
                <div class="col mb-2">
                    <div class="row">
                        <div class="col">
                            {{ form_widget(joolen_member_registration_point_during_period) }}
                        </div>
                        <div class="form-row col-10 pl-0">
                            {{ form_widget(joolen_member_registration_point_period_start) }}
                            <div class="col-auto">
                                <span style="line-height: 33px;">{{ 'admin.common.separator__range'|trans }}</span>
                            </div>
                            {{ form_widget(joolen_member_registration_point_period_end) }}
                        </div>
                    </div>
                    {{ form_errors(joolen_member_registration_point_during_period) }}
                    {{ form_errors(joolen_member_registration_point_period_start) }}
                    {{ form_errors(joolen_member_registration_point_period_end) }}
                </div>
            </div>

            {# メルマガ受け取り条件 #}
            {% if form.joolen_include_receiving_mail_magazine is defined %}
                {% set joolen_include_receiving_mail_magazine = form.joolen_include_receiving_mail_magazine %}
                <div class="row">
                    <div class="col-3">
                        <div class="d-inline-block">
                            <div
                                    class="d-inline-block"
                                    data-tooltip="true"
                                    data-placement="top"
                                    title="{{ 'joolenpointsformemberregistration4.admin.setting.shop.joolen_include_receiving_mail_magazine.help'|trans }}"
                            >
                                <span>{{ 'joolenpointsformemberregistration4.admin.setting.shop.joolen_include_receiving_mail_magazine'|trans }}</span>
                                <i class="fa fa-question-circle fa-lg ml-1"></i>
                            </div>
                        </div>
                    </div>
                    <div class="col mb-2">
                        <div class="input-group col-2 pl-0">
                            <div class="input-group">
                                {{ form_widget(joolen_include_receiving_mail_magazine) }}
                                {{ form_errors(joolen_include_receiving_mail_magazine) }}
                            </div>
                        </div>
                    </div>
                </div>
            {% endif %}

        </div>
    </div>
{% endblock %}

