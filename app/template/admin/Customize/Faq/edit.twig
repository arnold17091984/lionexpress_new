{% extends '@admin/default_frame.twig' %}

{% set menus = ['content'] %}

{% block title %}{% if Faq.id %}FAQ編集{% else %}FAQ新規追加{% endif %}{% endblock %}
{% block sub_title %}コンテンツ管理{% endblock %}

{% form_theme form '@admin/Form/bootstrap_4_horizontal_layout.html.twig' %}

{% block main %}
<form role="form" class="form-horizontal" method="post" action="?">
    {{ form_widget(form._token) }}
    <div class="c-contentsArea__cols">
        <div class="c-contentsArea__primaryCol">
            <div class="c-primaryCol">
                <div class="card rounded border-0 mb-4">
                    <div class="card-header">
                        <span class="card-title">FAQ情報</span>
                    </div>
                    <div class="card-body">

                        <div class="row mb-3">
                            <div class="col-3"><span>質問 <span class="badge badge-danger">必須</span></span></div>
                            <div class="col">
                                {{ form_widget(form.question) }}
                                {{ form_errors(form.question) }}
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-3"><span>回答 <span class="badge badge-danger">必須</span></span></div>
                            <div class="col">
                                {{ form_widget(form.answer) }}
                                {{ form_errors(form.answer) }}
                                <small class="form-text text-muted">改行はそのまま反映されます。</small>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-3"><span>並び順</span></div>
                            <div class="col-3">
                                {{ form_widget(form.sort_no) }}
                                {{ form_errors(form.sort_no) }}
                                <small class="form-text text-muted">数字が小さいほど上に表示されます。</small>
                            </div>
                        </div>

                    </div>
                </div>
            </div>

            <div class="c-conversionArea">
                <div class="c-conversionArea__container">
                    <div class="row justify-content-between align-items-center">
                        <div class="col-6">
                            <a class="c-baseLink" href="{{ url('admin_content_faq') }}">
                                <i class="fa fa-backward"></i> FAQ一覧に戻る
                            </a>
                        </div>
                        <div class="col-6">
                            <div class="row align-items-center justify-content-end">
                                <div class="col-auto">
                                    {{ form_widget(form.visible) }}
                                    {{ form_errors(form.visible) }}
                                </div>
                                <div class="col-auto">
                                    <button class="btn btn-ec-conversion px-5" type="submit">保存</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>
{% endblock %}
