{% extends '@admin/default_frame.twig' %}

{% set menus = ['content'] %}

{% block title %}FAQ管理{% endblock %}
{% block sub_title %}コンテンツ管理{% endblock %}

{% block main %}
<div class="c-contentsArea__cols">
    <div class="c-contentsArea__primaryCol">
        <div class="c-primaryCol">
            <div class="d-block mb-3">
                <a class="btn btn-ec-regular" href="{{ url('admin_content_faq_new') }}">
                    <i class="fa fa-plus"></i> 新規FAQ追加
                </a>
            </div>
            <div class="card rounded border-0 mb-4">
                <div class="card-body p-0">
                    <table class="table table-bordered mb-0">
                        <thead class="thead-light">
                            <tr>
                                <th style="width:60px">並び順</th>
                                <th>質問</th>
                                <th style="width:80px">表示</th>
                                <th style="width:100px">操作</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for Faq in faqs %}
                            <tr>
                                <td class="text-center align-middle">{{ Faq.sortNo }}</td>
                                <td class="align-middle">
                                    <a href="{{ url('admin_content_faq_edit', {id: Faq.id}) }}">
                                        {{ Faq.question }}
                                    </a>
                                </td>
                                <td class="text-center align-middle">
                                    {% if Faq.visible %}
                                        <span class="badge badge-success">表示</span>
                                    {% else %}
                                        <span class="badge badge-secondary">非表示</span>
                                    {% endif %}
                                </td>
                                <td class="text-center align-middle">
                                    <a class="btn btn-sm btn-ec-actionIcon"
                                       href="{{ url('admin_content_faq_edit', {id: Faq.id}) }}"
                                       title="編集">
                                        <i class="fa fa-pencil fa-lg text-secondary"></i>
                                    </a>
                                    <a class="btn btn-sm btn-ec-actionIcon"
                                       data-toggle="modal"
                                       data-target="#delete_{{ Faq.id }}"
                                       title="削除">
                                        <i class="fa fa-close fa-lg text-secondary"></i>
                                    </a>
                                    <div class="modal fade" id="delete_{{ Faq.id }}" tabindex="-1" role="dialog">
                                        <div class="modal-dialog" role="document">
                                            <div class="modal-content">
                                                <div class="modal-header">
                                                    <h5 class="modal-title font-weight-bold">削除確認</h5>
                                                    <button class="close" type="button" data-dismiss="modal"><span>×</span></button>
                                                </div>
                                                <div class="modal-body text-left">
                                                    <p>「{{ Faq.question }}」を削除しますか？</p>
                                                </div>
                                                <div class="modal-footer">
                                                    <button class="btn btn-ec-sub" type="button" data-dismiss="modal">キャンセル</button>
                                                    <a class="btn btn-ec-delete"
                                                       href="{{ url('admin_content_faq_delete', {id: Faq.id}) }}"
                                                       {{ csrf_token_for_anchor() }}
                                                       data-method="delete"
                                                       data-confirm="false">削除</a>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                            {% else %}
                            <tr>
                                <td colspan="4" class="text-center text-muted py-4">FAQがまだありません</td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
