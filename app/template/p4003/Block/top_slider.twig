    $(".top_visual").slick({
        asNavFor:".top_item_nav",
        autoplay: true,
        autoplaySpeed: 6000,
        speed: 1000,
    });
    $(".top_item_nav").slick({
        asNavFor:".top_visual",
        slidesToShow: 3,
    });
    $(".top_item_nav .slick-slide").on("click",function(){
        let index=$(this).attr("data-slick-index")
        $(".top_visual").slick("slickGoTo",index)
    })
});
</script>
