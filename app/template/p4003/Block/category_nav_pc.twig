    <a href="{{ url('entry') }}">
      <img src="{{ asset('assets/img/common/mailmagazine.gif') }}" alt="メルマガ登録">
    </a>
  </li>
  <li class="ec-sideBannerButton__item">
    <a href="{{ url('homepage') }}">
      <img src="{{ asset('/html/user_data/assets/img/banner/インスタグラムバナー.jpg') }}" alt="Instagram">
