<style>
.nd-utility-bar{background:#f8f8f8;border-bottom:1px solid #eee;padding:0;display:none}
@media(min-width:768px){.nd-utility-bar{display:block}}
.nd-utility-bar .nd-utility-links{display:flex;flex-direction:row;justify-content:flex-end;align-items:center;gap:0;list-style:none;margin:0 auto;padding:0;max-width:1200px}
.nd-utility-bar .nd-utility-links li{display:inline-block;width:auto;margin:0;padding:0}
.nd-utility-bar .nd-utility-links li a{display:inline-flex;align-items:center;gap:4px;padding:8px 14px;font-size:12px;color:#555;text-decoration:none;border-left:1px solid #e5e5e5;white-space:nowrap}
.nd-utility-bar .nd-utility-links li:last-child a{border-right:1px solid #e5e5e5}
.nd-utility-bar .nd-utility-links li a:hover{background:#eef5f5;color:#518889}
.header2 .nd-header-search{flex:1;max-width:440px;margin:0 20px}
.header2 .nd-header-search form{display:flex;border:2px solid #518889;border-radius:8px;overflow:hidden;width:100%;margin:0;padding:0}
.header2 .nd-header-search input[type="search"]{flex:1;padding:10px 14px;border:none;font-size:14px;outline:none;background:#fff;min-width:0;box-shadow:none;border-radius:0;margin:0;height:auto;-webkit-appearance:none}
.header2 .nd-header-search button{background:#518889;border:none;padding:0 16px;cursor:pointer;display:flex;align-items:center;justify-content:center;border-radius:0;min-width:48px}
.header2 .nd-header-search button:hover{background:#3d6b6c}
.header2 .nd-header-phone{display:flex;flex-direction:column;align-items:flex-end;margin-right:16px;white-space:nowrap}
.nd-phone-link{display:inline-flex;align-items:center;gap:6px;text-decoration:none}
.nd-phone-number{font-size:22px;font-weight:700;color:#333;letter-spacing:.5px;line-height:1}
.nd-phone-hours{font-size:11px;color:#888;margin-top:2px}

/* ── Mobile header: 2-row layout ── */
@media(max-width:767px){
  .nd-header-search{display:none!important}
  .header2{
    display:grid!important;
    grid-template-columns:auto 1fr auto!important;
    grid-template-rows:auto auto!important;
    align-items:center!important;
    padding:8px 12px 4px!important;
    gap:0 8px!important;
  }
  /* Row 1: Logo | Phone | Icons+Cart */
  .header2 .ec-headerRole__title{
    grid-column:1!important;grid-row:1!important;
    max-width:100px!important;
  }
  .header2 .ec-headerRole__title img{height:32px!important;width:auto!important}
  .header2 .nd-header-phone{
    display:flex!important;
    grid-column:2!important;grid-row:1!important;
    flex-direction:row!important;
    align-items:center!important;
    gap:6px!important;
    margin:0!important;
    justify-content:center!important;
  }
  .nd-phone-number{font-size:15px!important;font-weight:700!important}
  .nd-phone-hours{
    font-size:9px!important;
    margin-top:0!important;
    color:#999!important;
    white-space:nowrap!important;
  }
  .header2 .icon-items{
    grid-column:3!important;grid-row:1!important;
    gap:2px!important;
    justify-content:flex-end!important;
  }
  .header2 .icon-items .nd-header-icon{width:22px!important;height:22px!important}
  .header2 .nd-header-icon-label{font-size:8px!important}
  .header2 .ec-headerRole__cart{
    grid-column:3!important;grid-row:1!important;
  }

  /* Row 2: phone hours below - hide separate, show inline */
  .header2 .nd-header-phone{
    flex-wrap:wrap!important;
    justify-content:flex-start!important;
  }
}
@media(max-width:374px){
  .header2 .ec-headerRole__title img{height:28px!important}
  .nd-phone-number{font-size:13px!important}
  .nd-phone-hours{display:none!important}
}
</style>
