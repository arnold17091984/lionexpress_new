{% set Categories = repository('Eccube\\Entity\\Category').getList() %}

<div class="ec-drawerRole">
  <div class="nd-drawer-header">
    <a href="{{ url('homepage') }}" class="nd-drawer-logo">
      <img src="{{ asset('assets/img/common/logo_1_2.png', 'user_data') }}" alt="{{ BaseInfo.shop_name }}" height="28">
    </a>
    <button class="nd-drawer-close ec-drawerRole__close" aria-label="メニューを閉じる">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
  </div>

  <div class="nd-drawer-body">
    <nav>
      <ul class="nd-drawer-menu">
        {% if is_granted('ROLE_USER') %}
          <li>
            <a href="{{ url('mypage') }}" class="nd-drawer-link">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
              マイページ
            </a>
          </li>
          <li>
            <a href="{{ url('mypage_favorite') }}" class="nd-drawer-link">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
              お気に入り
            </a>
          </li>
          <li>
            <a href="{{ url('mypage') }}" class="nd-drawer-link">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
              注文履歴
            </a>
          </li>
          <li>
            <a href="{{ url('logout') }}" class="nd-drawer-link">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
              ログアウト
            </a>
          </li>
        {% else %}
          <li>
            <a href="{{ url('mypage_login') }}" class="nd-drawer-link">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg>
              ログイン
            </a>
          </li>
          <li>
            <a href="{{ url('entry') }}" class="nd-drawer-link">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/></svg>
              新規会員登録
            </a>
          </li>
        {% endif %}

        <li class="nd-drawer-divider"></li>

        <li>
          <a href="{{ url('help_about') }}" class="nd-drawer-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            初めての方へ
          </a>
        </li>
        <li>
          <a href="/guide" class="nd-drawer-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
            ご利用方法
          </a>
        </li>

        <li class="nd-drawer-divider"></li>

        <li>
          <a href="{{ url('product_list') }}" class="nd-drawer-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
            全商品を見る
          </a>
        </li>

        <li>
          <a href="{{ url('contact') }}" class="nd-drawer-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            お問い合わせ
          </a>
        </li>

        <li>
          <a href="https://line.me/R/ti/p/@229ulhco" class="nd-drawer-link" target="_blank" rel="noopener noreferrer">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            LINEで問い合わせ
          </a>
        </li>

        <li class="nd-drawer-divider"></li>

        {# Categories accordion #}
        <li class="nd-drawer-accordion">
          <button class="nd-drawer-link nd-drawer-toggle" aria-expanded="false">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
            商品カテゴリ
            <svg class="nd-drawer-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
          <ul class="nd-drawer-sub">
            {% for Category in Categories %}
              <li>
                <a href="{{ url('product_list') }}?category_id={{ Category.id }}">{{ Category.name }}</a>
                {% if Category.children|length > 0 %}
                  <ul class="nd-drawer-sub-child">
                    {% for ChildCategory in Category.children %}
                      <li><a href="{{ url('product_list') }}?category_id={{ ChildCategory.id }}">{{ ChildCategory.name }}</a></li>
                    {% endfor %}
                  </ul>
                {% endif %}
              </li>
            {% endfor %}
          </ul>
        </li>

        <li class="nd-drawer-divider"></li>

        <li>
          <a href="{{ url('help_about') }}" class="nd-drawer-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
            当サイトについて
          </a>
        </li>
      </ul>
    </nav>
  </div>
</div>
<div class="ec-drawerOverlay"></div>

<script>
$(function() {
    $('.ec-drawerRole__close, .nd-drawer-close, .ec-drawerOverlay').on('click', function() {
        $('.ec-headerHamburger').removeClass('is-active');
        $('.ec-drawerRole').removeClass('is-active');
        $('.ec-drawerOverlay').removeClass('is-active');
        $('body').removeClass('have-fixed');
    });

    $('.nd-drawer-toggle').on('click', function(e) {
        e.preventDefault();
        var $li = $(this).parent();
        var expanded = $(this).attr('aria-expanded') === 'true';
        $(this).attr('aria-expanded', !expanded);
        $li.toggleClass('is-open');
        $li.find('.nd-drawer-sub').first().slideToggle(250);
    });
});
</script>
