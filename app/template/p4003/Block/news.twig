{% set NewsList = repository('Eccube\\Entity\\News').getList() %}

{% if NewsList|length > 0 %}
<style>
.nd-news-strip {
  max-width: 880px;
  margin: -12px auto 0;
  padding: 0 20px;
  position: relative;
  z-index: 2;
}
.nd-news-card {
  background: #fff;
  border-radius: 12px;
  box-shadow: 0 2px 12px rgba(0,0,0,0.08);
  overflow: hidden;
}
.nd-news-items { list-style: none; margin: 0; padding: 0; }
.nd-news-row {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px 20px;
  cursor: pointer;
  transition: background 0.15s;
  border-bottom: 1px solid #f5f5f5;
}
.nd-news-row:last-child { border-bottom: none; }
.nd-news-row:hover { background: #fafcfc; }
.nd-news-date {
  font-size: 12px;
  font-weight: 600;
  color: var(--brand-primary, #518889);
  flex-shrink: 0;
  font-variant-numeric: tabular-nums;
}
.nd-news-label {
  font-size: 10px;
  font-weight: 700;
  color: var(--brand-dark, #2d5a5b);
  background: var(--brand-bg, #f0f8f8);
  padding: 2px 8px;
  border-radius: 4px;
  flex-shrink: 0;
}
.nd-news-new {
  font-size: 9px;
  font-weight: 700;
  color: #fff;
  background: var(--accent-red, #e84545);
  padding: 2px 7px;
  border-radius: 4px;
  flex-shrink: 0;
}
.nd-news-title {
  flex: 1;
  font-size: 13px;
  font-weight: 500;
  color: #333;
  line-height: 1.5;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.nd-news-chevron {
  width: 14px; height: 14px;
  color: #ccc;
  flex-shrink: 0;
  transition: transform 0.25s, color 0.2s;
}
.nd-news-row.is-open .nd-news-chevron {
  transform: rotate(180deg);
  color: var(--brand-primary, #518889);
}
.nd-news-detail {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.3s;
}
.nd-news-detail-inner {
  padding: 0 20px 12px;
  font-size: 13px;
  color: #666;
  line-height: 1.8;
}
.nd-news-detail-inner a {
  color: var(--brand-primary, #518889);
  font-weight: 600;
  text-decoration: none;
}
.nd-news-detail-inner a:hover { text-decoration: underline; }
.nd-news-more-row {
  display: block;
  width: 100%;
  padding: 10px;
  text-align: center;
  font-size: 12px;
  font-weight: 600;
  color: var(--brand-primary, #518889);
  background: #fafcfc;
  border: none;
  border-top: 1px solid #f0f0f0;
  cursor: pointer;
  transition: background 0.15s;
}
.nd-news-more-row:hover { background: #f0f7f7; }
@media (max-width: 600px) {
  .nd-news-strip { margin-top: -8px; padding: 0 12px; }
  .nd-news-row { padding: 10px 14px; gap: 8px; }
  .nd-news-title { font-size: 12px; }
  .nd-news-detail-inner { padding: 0 14px 10px; }
}
</style>

<div class="nd-news-strip">
  <div class="nd-news-card">
    <ul class="nd-news-items">
      {% for News in NewsList %}
      <li {% if loop.index > 3 %}style="display:none" class="nd-news-hidden"{% endif %}>
        <div class="nd-news-row">
          <span class="nd-news-date">{{ News.publish_date|date_day }}</span>
          <span class="nd-news-label">NEWS</span>
          {% if loop.first %}<span class="nd-news-new">NEW</span>{% endif %}
          <span class="nd-news-title">{{ News.title }}</span>
          {% if News.description or News.url %}
          <svg class="nd-news-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
          {% endif %}
        </div>
        {% if News.description or News.url %}
        <div class="nd-news-detail">
          <div class="nd-news-detail-inner">
            {{ News.description|raw|nl2br }}
            {% if News.url %}
            <br><a href="{{ News.url }}" {% if News.link_method == '1' %}target="_blank" rel="noopener noreferrer"{% endif %}>詳しくはこちら →</a>
            {% endif %}
          </div>
        </div>
        {% endif %}
      </li>
      {% endfor %}
    </ul>
    {% if NewsList|length > 3 %}
    <button class="nd-news-more-row" type="button">他のお知らせを見る（{{ NewsList|length }}件）</button>
    {% endif %}
  </div>
</div>

<script>
$(function(){
  $('.nd-news-row').on('click', function(){
    var $row = $(this), $detail = $row.parent().find('.nd-news-detail');
    if (!$detail.length) return;
    if ($row.hasClass('is-open')) {
      $row.removeClass('is-open');
      $detail.css('max-height', 0);
    } else {
      $row.addClass('is-open');
      $detail.css('max-height', $detail[0].scrollHeight + 'px');
    }
  });
  $('.nd-news-more-row').on('click', function(){
    $('.nd-news-hidden').slideDown(200);
    $(this).fadeOut(150);
  });
});
</script>
{% endif %}
