{% form_theme form 'Form/form_div_layout.twig' %}
<div class="nd-search-bar">
  <form method="get" class="nd-search-form" action="{{ path('product_list') }}">
    <input type="hidden" name="search_select" value="search_default">
    <div class="nd-search-input-wrap">
      <svg class="nd-search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none"
           stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"
           aria-hidden="true">
        <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
      </svg>
      {{ form_widget(form.name, {
        'id': null,
        'attr': {
          'class': 'nd-search-input',
          'placeholder': '商品名を入力してください（例：バイアグラ、プロペシア）',
          'autocomplete': 'off'
        }
      }) }}
    </div>
    <button class="nd-search-btn" type="submit" aria-label="検索">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
           stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"
           aria-hidden="true">
        <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
      </svg>
      <span class="nd-search-btn-label">検索</span>
    </button>
  </form>
  <div class="nd-mobile-phone">
    <a href="tel:0368246593">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="#518889"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>
      03-6824-6593
    </a>
    <span>受付 10:00〜18:00（土日祝休み）</span>
  </div>
  <p class="nd-search-notice">日本の薬機法で医薬品名を一般公開出来ません。個人輸入医薬品は商品名を正確に入力してください</p>
</div>
