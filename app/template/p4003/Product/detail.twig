{% extends 'default_frame.twig' %}

{% set body_class = 'product_page' %}

{# Styles moved to theme SCSS: _105.1.product.scss #}
{% block stylesheet %}
<style>
/* ===================================================
   Product detail — Apple-quality critical overrides
   =================================================== */

/* ── 1. TWO-COLUMN LAYOUT ── */
.ec-productRole > .ec-grid2 {
  display: flex !important;
  align-items: flex-start !important;
  gap: 3rem !important;
  padding: 2rem 5% !important;
  border-bottom: none !important;
}
.ec-grid2__cell.cell_left  { flex: 0 0 34% !important; max-width: 34% !important; }
.ec-grid2__cell.cell_right { flex: 1 !important; min-width: 0 !important; }

/* ── 2. PRODUCT IMAGE: fill container ── */
.ec-sliderItemRole { width: 100% !important; }
.ec-sliderItemRole img { width: 100% !important; height: auto !important; display: block !important; border-radius: 10px !important; }
.item_visual .slide-item img { width: 100% !important; height: auto !important; object-fit: contain !important; border-radius: 10px !important; border: 1px solid #eee !important; }
.item_nav { display: flex !important; gap: 6px !important; margin-top: 10px !important; flex-wrap: wrap !important; }
.item_nav .slideThumb { width: 60px !important; height: 60px !important; overflow: hidden !important; border-radius: 6px !important; border: 2px solid transparent !important; cursor: pointer !important; flex-shrink: 0 !important; }
.item_nav .slideThumb img { width: 100% !important; height: 100% !important; object-fit: cover !important; }
.item_nav .slideThumb:hover { border-color: #518889 !important; }

/* ── 3. PRODUCT NAME ── */
.ec-productRole h1 {
  font-size: clamp(1.6rem, 2.5vw, 2.2rem) !important;
  font-weight: 700 !important;
  line-height: 1.3 !important;
  color: #1a3333 !important;
  margin: 0 0 0.3rem !important;
  letter-spacing: -0.02em !important;
}
.update_date { font-size: 1.2rem !important; color: #999 !important; margin-bottom: 1rem !important; }

/* ── 4. SPEC TABLE: remove teal background ── */
.ct { width: 100% !important; border-collapse: collapse !important; margin-bottom: 1.2rem !important; border: 1px solid #eee !important; border-radius: 8px !important; overflow: hidden !important; }
.ct tr { display: flex !important; border-bottom: 1px solid #f0f0f0 !important; }
.ct tr:last-child { border-bottom: none !important; }
td.ttitle, .ttitle {
  display: flex !important; align-items: center !important;
  flex: 0 0 30% !important; max-width: 30% !important;
  background: #f2f5f5 !important;
  color: #3a5a5a !important;
  font-weight: 600 !important;
  font-size: 1.4rem !important; /* was 0.9rem=9px — unreadable */
  padding: 10px 12px !important;
  border: none !important;
  border-radius: 0 !important;
  border-right: 1px solid #e5eaea !important;
}
td.tvalue, .tvalue {
  flex: 1 !important;
  background: #fff !important;
  color: #222 !important;
  padding: 10px 14px !important;
  border: none !important;
  font-size: 1.5rem !important; /* was 0.95rem=9.5px — unreadable */
  line-height: 1.6 !important;
  vertical-align: middle !important;
}

/* ── 5. BUTTONS ── */
.ec-productRole__btn { margin-top: 1rem !important; }
.ec-productRole__btn .ec-blockBtn--action {
  background: #e07b00 !important;
  background-image: none !important;
  color: #fff !important;
  border-radius: 10px !important;
  font-size: 1.6rem !important; /* was 1rem=10px — unreadable */
  font-weight: 700 !important;
  padding: 16px !important;
  border: none !important;
  width: 100% !important;
  cursor: pointer !important;
}
.ec-productRole__btn .ec-blockBtn--cancel {
  border-radius: 10px !important;
  font-weight: 600 !important;
  margin-top: 0.5rem !important;
}

/* ── 6. SECTION HEADINGS (服用方法・副作用・etc) ── */
#item_howto h2, #item_sideeffect h2, #item_caution h2,
#item_keep h2, #item_maker h2, #item_shipped h2, #item_review h2 {
  background: none !important;
  color: #1a3333 !important;
  font-size: 1.8rem !important; /* was 1.15rem=11.5px — too small */
  font-weight: 700 !important;
  padding: 1rem 5% 0.5rem !important;
  border-bottom: 2px solid #518889 !important;
  border-radius: 0 !important;
  margin: 0 !important;
  cursor: pointer !important;
}
.item_text {
  background: #f9fbfb !important;
  padding: 1rem 5% 1rem !important;
  line-height: 1.9 !important;
  font-size: 1.6rem !important; /* was 0.95rem=9.5px — unreadable */
  color: #333 !important;
}
section.no_padding { margin-top: 1.5rem !important; }

/* ── 7. ORDER TABLE ── */
#item_order { padding: 0 5% !important; }
#item_order h2 {
  background: none !important;
  color: #1a3333 !important;
  font-size: 1.8rem !important; /* was 1.15rem=11.5px — too small */
  font-weight: 700 !important;
  padding: 1rem 0 0.5rem !important;
  border-bottom: 2px solid #518889 !important;
  border-radius: 0 !important;
}
.order_tbl { width: 100% !important; border-collapse: collapse !important; box-shadow: 0 1px 6px rgba(0,0,0,0.07) !important; border-radius: 10px !important; overflow: hidden !important; margin: 1rem 0 !important; }
.order_tbl th { background: #518889 !important; color: #fff !important; padding: 10px 12px !important; font-size: 1.4rem !important; /* was 0.88rem=8.8px */ font-weight: 600 !important; border: none !important; text-align: center !important; }
.order_tbl td { padding: 12px !important; border-bottom: 1px solid #f0f0f0 !important; background: #fff !important; text-align: center !important; vertical-align: middle !important; font-size: 1.5rem !important; /* was 0.95rem=9.5px */ }
.order_tbl tr:last-child td { border-bottom: none !important; }
.order_tbl .basic del { color: #aaa !important; font-size: 0.85em !important; display: block !important; }
.order_tbl .sale strong { color: #1a3333 !important; font-size: 1.5rem !important; /* was 1.1rem=11px */ font-weight: 700 !important; }
.order_tbl .sale .unit { color: #666 !important; font-size: 1.2rem !important; /* was 0.8rem=8px */ display: block !important; }
.order_tbl .btn.add-cart, .order_tbl .btn.ga4_addtocart {
  background: #e07b00 !important; background-image: none !important;
  color: #fff !important; border-radius: 8px !important;
  font-weight: 700 !important; font-size: 1.4rem !important; /* was 0.9rem=9px */
  padding: 10px 16px !important; border: none !important;
  cursor: pointer !important; white-space: nowrap !important;
}
.order_tbl .btn.add-cart:hover { background: #c46b00 !important; }

/* ── 8. RELATED PRODUCTS title ── */
.RelatedProduct_title {
  background: none !important; background-color: transparent !important;
  color: #1a3333 !important; border: none !important;
  border-bottom: 2px solid #518889 !important;
  font-size: 1.6rem !important; /* was 1.1rem=11px */ font-weight: 700 !important;
  padding: 0 0 0.5rem !important; margin-bottom: 1rem !important;
  border-left: none !important; border-radius: 0 !important;
}

/* ── 9. TAGS ── */
.ec-productRole__tags { padding: 0.5rem 0 !important; border-bottom: none !important; display: flex !important; flex-wrap: wrap !important; gap: 4px !important; }
.ec-productRole__tag { padding: 3px 10px !important; border-radius: 20px !important; font-size: 1.2rem !important; /* was 0.78rem=7.8px — unreadable */ font-weight: 600 !important; }

/* ── 10. MOBILE ── */
@media (max-width: 767px) {
  .ec-productRole > .ec-grid2 { flex-direction: column !important; gap: 0 !important; padding: 1rem !important; }
  .ec-grid2__cell.cell_left, .ec-grid2__cell.cell_right { flex: none !important; max-width: 100% !important; width: 100% !important; }
  .ct tr { flex-direction: column !important; }
  td.ttitle, .ttitle { flex: none !important; max-width: 100% !important; border-right: none !important; border-bottom: 1px solid #e5eaea !important; }
}

/* ── 11. ACCORDION CHEVRON — .icon inside h2 ── */
#item_howto h2, #item_sideeffect h2, #item_caution h2,
#item_keep h2, #item_maker h2, #item_shipped h2, #item_review h2 {
  display: flex !important;
  justify-content: space-between !important;
  align-items: center !important;
}
.icon {
  display: inline-block !important;
  width: 14px !important;
  height: 14px !important;
  border-right: 2.5px solid #518889 !important;
  border-bottom: 2.5px solid #518889 !important;
  transform: rotate(45deg) !important;
  transition: transform 0.22s ease, margin-top 0.22s ease !important;
  flex-shrink: 0 !important;
  margin-top: -6px !important;
}
.icon.open {
  transform: rotate(-135deg) !important;
  margin-top: 4px !important;
}
</style>
{% endblock %}


{% block javascript %}
    <script>
        eccube.classCategories = {{ class_categories_as_json(Product)|raw }};

        // 規格2に選択肢を割り当てる。
        function fnSetClassCategories(form, classcat_id2_selected) {
            var $form = $(form);
            var product_id = $form.find('input[name=product_id]').val();
            var $sele1 = $form.find('select[name=classcategory_id1]');
            var $sele2 = $form.find('select[name=classcategory_id2]');
            eccube.setClassCategories($form, product_id, $sele1, $sele2, classcat_id2_selected);
        }

        {% if form.classcategory_id2 is defined %}
        fnSetClassCategories(
            $('#form1'), {{ form.classcategory_id2.vars.value|json_encode|raw }}
        );
        {% elseif form.classcategory_id1 is defined %}
        eccube.checkStock($('#form1'), {{ Product.id }}, {{ form.classcategory_id1.vars.value|json_encode|raw }}, null);
        {% endif %}
    </script>
    <script>
        $(function() {
            // bfcache無効化
            $(window).bind('pageshow', function(event) {
                if (event.originalEvent.persisted) {
                    location.reload(true);
                }
            });

            $('.item_visual').slick({
                dots: false,
                arrows: false,
                responsive: [{
                    breakpoint: 768,
                    settings: {
                        dots: true
                    }
                }]
            });

            $('.slideThumb').on('click', function() {
                var index = $(this).attr('data-index');
                $('.item_visual').slick('slickGoTo', index, false);
            })
        });
    </script>
    <script>
        $(function() {
            $('.add-cart').on('click', function(event) {
//                {% if form.classcategory_id1 is defined %}
//                // 規格1フォームの必須チェック
//                if ($('#classcategory_id1').val() == '__unselected' || $('#classcategory_id1').val() == '') {
//                    $('#classcategory_id1')[0].setCustomValidity('{{ '項目が選択されていません'|trans }}');
//                    return true;
//                } else {
//                    $('#classcategory_id1')[0].setCustomValidity('');
//                }
//                {% endif %}
//
//                {% if form.classcategory_id2 is defined %}
//                // 規格2フォームの必須チェック
//                if ($('#classcategory_id2').val() == '__unselected' || $('#classcategory_id2').val() == '') {
//                    $('#classcategory_id2')[0].setCustomValidity('{{ '項目が選択されていません'|trans }}');
//                    return true;
//                } else {
//                    $('#classcategory_id2')[0].setCustomValidity('');
//                }
//                {% endif %}
//
//                // 個数フォームのチェック
//                if ($('#quantity').val() < 1) {
//                    $('#quantity')[0].setCustomValidity('{{ '1以上で入力してください。'|trans }}');
//                    return true;
//                } else {
//                    $('#quantity')[0].setCustomValidity('');
//                }

                event.preventDefault();
                var btnId = $(this).attr('id');
                if (!btnId) {
                    // Hero button has no ID — use first ProductClass option
                    var firstBtn = $('.add-cart[id^="pc_"]').first();
                    if (firstBtn.length) {
                        btnId = firstBtn.attr('id');
                    } else {
                        return;
                    }
                }
                var id = btnId.replace("pc_", "");
                $('#ProductClass').val(id);
                var $form = $('#form1');
                $.ajax({
                    url: $form.attr('action'),
                    type: $form.attr('method'),
                    data: $form.serialize(),
                    dataType: 'json',
                    beforeSend: function(xhr, settings) {
                        // Buttonを無効にする
                        $('.add-cart').prop('disabled', true);
                    }
                }).done(function(data) {
                    // レスポンス内のメッセージを表示
                    $.each(data.messages, function() {
                        $('#ec-modal-header').text(this);
                    });

                    $('.ec-modal').show()

                    // カートブロックを更新する
                    $.ajax({
                        url: "{{ url('block_cart') }}",
                        type: 'GET',
                        dataType: 'html'
                    }).done(function(html) {
                        $('.ec-headerRole__cart').html(html);
                    }).fail(function() {
                        console.warn('Cart block update failed');
                    });
                }).fail(function(data) {
                    alert('{{ 'カートへの追加に失敗しました。'|trans }}');
                }).always(function(data) {
                    // Buttonを有効にする
                    $('.add-cart').prop('disabled', false);
                });
            });

            // モーダルウィンドウを開く
            var scrollPosition = 0;
            $('.js-modal-open').on('click', function(){
                var target = $(this).data('target');
                var modal = document.getElementById(target);
                scrollPosition = $(window).scrollTop();
                $('body').addClass('fixed').css({'top': -scrollPosition});
                $(modal).fadeIn();
                return false;
            });

            // モーダルウィンドウを閉じる
            $('.js-modal-close').on('click', function(){
                $('body').removeClass('fixed');
                window.scrollTo( 0 , scrollPosition );
                $('.js-modal').fadeOut();
                return false;
            });

            $('a[href^="#"]').click(function(){
                var adjust = 0;
                var speed = 400;
                var href= $(this).attr("href");
                var target = $(href == "#" || href == "" ? 'html' : href);
                if (!target.length) return false;
                var position = target.offset().top + adjust;
                $('body,html').animate({scrollTop:position}, speed, 'swing');
                return false;
            });

            // Cart modal close handlers (inside DOMReady)
            $('.ec-modal-wrap').on('click', function(e) {
                e.stopPropagation();
            });
            $('.ec-modal-overlay, .ec-modal-close, .ec-inlineBtn--cancel').on('click', function() {
                $('.ec-modal').hide()
            });
        });
    </script>


    <script>
    $(function() {
        // Accordion toggle — scoped to sections with .icon chevrons only
        $('#item_howto h2, #item_sideeffect h2, #item_caution h2, #item_keep h2, #item_maker h2, #item_shipped h2, #item_review h2').on('click', function() {
            $(this).find(".icon").toggleClass('open');
            $(this).next().slideToggle();
        });
        // var value = $('#item_detail').find('h2').html();
        // value = value + '<div class="icon"></div>';
        // $('#item_detail').find('h2').html(value);
        $('.item_text').hide();
        // $('.review-box').hide();
        $('#item_review').find('.ec-role').hide();
    });
    </script>


    <script type="application/ld+json">
    {
        "@context": "https://schema.org/",
        "@type": "Product",
        "name": "{{ Product.name }}",
        "image": [
            {% for img in Product.ProductImage %}
                "{{ app.request.schemeAndHttpHost }}{{ asset(img, 'save_image') }}"{% if not loop.last %},{% endif %}

            {% else %}
                "{{ app.request.schemeAndHttpHost }}{{ asset(''|no_image_product, 'save_image') }}"
            {% endfor %}
        ],
        "description": "{{ Product.description_list | default(Product.description_detail) | replace({'\n': '', '\r': ''}) | slice(0,300) }}",
        {% if Product.code_min %}
        "sku": "{{ Product.code_min }}",
        {% endif %}
        "brand": {
            "@type": "Brand",
            "name": "{{ Product.maker_name|default(BaseInfo.shop_name) }}"
        },
        "offers": {
            "@type": "Offer",
            "url": "{{ url('product_detail', {'id': Product.id}) }}",
            "priceCurrency": "{{ eccube_config.currency }}",
            "price": {{ Product.getPrice02IncTaxMin }},
            "availability": "https://schema.org/{{ Product.stock_find ? 'InStock' : 'OutOfStock' }}",
            "seller": {
                "@type": "Organization",
                "name": "{{ BaseInfo.shop_name }}"
            }
        }
    }
    </script>
{% endblock %}

{% block main %}
    <div class="ec-productRole">
        <div class="ec-grid2">
            <div class="sp-only">
                <div class="update_date">更新日：<time>{{ Product.update_date|date_format('', 'Y年m月d日') }}</time></div>
                <h1>{{ Product.name }}</h1>
            </div>
            <div class="ec-grid2__cell cell_left">
                <div class="ec-sliderItemRole">

                    <div class="item_visual">
                        {% for ProductImage in Product.ProductImage %}
                            <div class="slide-item"><img src="{{ asset(ProductImage, 'save_image') }}" alt="{{ loop.first ? Product.name : '' }}"></div>
                        {% else %}
                            <div class="slide-item"><img src="{{ asset(''|no_image_product, 'save_image') }}" alt="{{ loop.first ? Product.name : '' }}" /></div>
                        {% endfor %}
                    </div>
                    <div class="item_nav">
                        {% for ProductImage in Product.ProductImage %}
                            <div class="slideThumb" data-index="{{ loop.index0 }}"><img src="{{ asset(ProductImage, 'save_image') }}" alt=""></div>
                        {% endfor %}
                    </div>
                </div>
            </div>
            <div class="ec-grid2__cell cell_right">
                <div class="ec-productRole__profile">
                    {# 商品名 #}
                    <div class="pc-only">
                        <div class="item_title">
                            <h1>{{ Product.name }}</h1>
                            <div class="update_date">更新日：<time>{{ Product.update_date|date_format('', 'Y年m月d日') }}</time></div>
                        </div>
                    </div>
                   {# タグ #}
                    <ul class="ec-productRole__tags">
                        {% for Tag in Product.Tags %}
                            <li class="ec-productRole__tag tag_{{ Tag.id }}">{{ Tag }}</li>
                        {% endfor %}
                    </ul>
                    {#{{ include('@DesignTag4/tag_list.twig', ignore_missing = true) }}#}
                    {#<div class="item_desc_body1">#}
                    {#    <ul class="item_tag">#}
                    {#        {% for Tag in Product.Tags %}#}
                    {#            <li>{{ Tag }}</li>#}
                    {#        {% endfor %}#}
                    {#    </ul>#}
                    {#</div>#}
                    {{ include('Block/product_table_list.twig') }}

                    {# レビュー #}
                    <div class="product-review">
                        {% set AvgGood = 0 %}
                        {% set AvgCnt = 0 %}
                        {% set AvgReview = getAvgReview(Product.id) %}
                        {% if AvgReview is not empty and AvgReview.star is defined and AvgReview.star is not null %}
                            {% set AvgGood = AvgReview.star * 2 %}
                            {% set AvgGood = AvgGood|round(0, 'floor') %}
                            {% set AvgGood = AvgGood / 2 %}
                        {% else %}
                            {% set AvgGood = 0 %}
                        {% endif %}
                        {% if AvgReview is not empty and AvgReview.cnt is defined and AvgReview.cnt is not null %}
                            {% set AvgCnt = AvgReview.cnt %}
                        {% endif %}
                        {% if AvgGood > 0 %}
                        <a href="#item_review">{{ getStar(AvgGood)|raw }}({{ AvgCnt }})</a>
                        {% endif %}
                    </div>
 
                    <form action="{{ url('product_add_cart', {id:Product.id}) }}" method="post" id="form1" name="form1">
                        {% if Product.stock_find %}
                            <div class="ec-productRole__actions">
                                {% if form.classcategory_id1 is defined %}
                                    <div class="ec-select">
                                        {{ form_widget(form.classcategory_id1) }}
                                        {{ form_errors(form.classcategory_id1) }}
                                    </div>
                                    {% if form.classcategory_id2 is defined %}
                                        <div class="ec-select">
                                            {{ form_widget(form.classcategory_id2) }}
                                            {{ form_errors(form.classcategory_id2) }}
                                        </div>
                                    {% endif %}
                                {% endif %}
                                <div class="ec-numberInput"><span>{{ '数量'|trans }}</span>
                                    {{ form_widget(form.quantity) }}
                                    {{ form_errors(form.quantity) }}
                                </div>
                            </div>
                            <div class="ec-productRole__btn">
                                <button type="submit" class="ec-blockBtn--action add-cart">
                                    {{ 'カートに入れる'|trans }}
                                </button>
                            </div>
                        {% else %}
                            <div class="ec-productRole__btn">
                                <button type="button" class="ec-blockBtn--action" disabled="disabled">
                                    {{ 'ただいま品切れ中です。'|trans }}
                                </button>
                            </div>
                        {% endif %}

                        {{ form_rest(form) }}
                    </form>
                    <div class="ec-modal">
                        <div class="ec-modal-overlay">
                            <div class="ec-modal-wrap">
                                <span class="ec-modal-close"><span class="ec-icon"><img src="{{ asset('assets/icon/cross-dark.svg') }}" alt=""/></span></span>
                                <div id="ec-modal-header" class="text-center">{{ 'カートに追加しました。'|trans }}</div>
                                <div class="ec-modal-box">
                                    <div class="ec-role">
                                        <span class="ec-inlineBtn--cancel">{{ 'お買い物を続ける'|trans }}</span>
                                        <a href="{{ url('cart') }}" class="ec-inlineBtn--action">{{ 'カートへ進む'|trans }}</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    {% if BaseInfo.option_favorite_product %}
                        <form action="{{ url('product_add_favorite', {id:Product.id}) }}" method="post">
                            <div class="ec-productRole__btn">
                                {% if is_favorite == false %}
                                    <button type="submit" id="favorite" class="ec-blockBtn--cancel">
                                        {{ 'お気に入りに追加'|trans }}
                                    </button>
                                {% else %}
                                    <button type="submit" class="ec-blockBtn--cancel"
                                            disabled="disabled">{{ 'お気に入りに追加済です。'|trans }}
                                    </button>
                                {% endif %}
                            </div>
                        </form>
                    {% endif %}
                    <div class="ec-productRole__description">{{ Product.description_detail|raw|nl2br }}
                    </div>
                </div>
            </div>
        </div>

        <section id="item_order" class="no_padding">
            <h2>ご注文<i id="order_arrow" class="fa fa-hand-o-left dsp_non" aria-hidden="true"></i></h2>
            <h3>{{ Product.name }}</h3>
            <table class="order_tbl pc-only">
                <tr>
                    <th>内容量</th>
                    <th colspan="2">販売価格</th>
                    <th>ポイント</th>
                    <th>注文</th>
                </tr>
                {% for ProductClass in Product.ProductClasses %}
                    {% set ClassCategory1 = ProductClass.ClassCategory1 %}
                    <tr>
                        <td>
                            {{ ClassCategory1.name }}
                        </td>
                        <td>
                            <div class="basic">
                                <del>
                                    <span>{{ ProductClass.price01|number_format }}<small>円</small></span>
                                </del>
                                <i class="fas fa-arrow-right"></i>
                            </div>
                        </td>
                        <td>
                            <div class="sale">
                                <strong>{{ ProductClass.price02|number_format }}<small>円</small></strong>
                                <span class="unit">
                                    {% set unitPrice = convertPrice(ClassCategory1.name, ProductClass.unit, ProductClass.price02) %}
                                    （{{ unitPrice|number_format }}<small>円</small>）
                                    <span class="title">1{{ ProductClass.unit }}あたり</span>
                                </span>
