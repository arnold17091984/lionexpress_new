{% extends 'default_frame.twig' %}

{% set body_class = 'mypage' %}

{% block stylesheet %}
<style>
/* ── Login page redesign ── */
.nd-login-wrap {
    max-width: 440px;
    margin: 40px auto 60px;
    padding: 0 20px;
}
.nd-login-card {
    background: #fff;
    border-radius: 16px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.08);
    padding: 40px 32px 32px;
}
.nd-login-header {
    text-align: center;
    margin-bottom: 28px;
}
.nd-login-header h1 {
    font-size: 22px;
    font-weight: 700;
    color: #1a1a1a;
    margin: 0 0 6px;
}
.nd-login-header p {
    font-size: 14px;
    color: #888;
    margin: 0;
}
.nd-login-icon {
    width: 56px;
    height: 56px;
    margin: 0 auto 16px;
    background: #f0f7f7;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
}
.nd-login-icon svg {
    width: 28px;
    height: 28px;
    color: #518889;
}

/* Form fields */
.nd-login-field {
    margin-bottom: 16px;
}
.nd-login-field label {
    display: block;
    font-size: 13px;
    font-weight: 600;
    color: #555;
    margin-bottom: 6px;
}
.nd-login-field input[type="email"],
.nd-login-field input[type="text"],
.nd-login-field input[type="password"] {
    width: 100%;
    padding: 12px 14px;
    border: 1.5px solid #ddd;
    border-radius: 10px;
    font-size: 15px;
    color: #333;
    background: #fafafa;
    transition: border-color 0.2s, box-shadow 0.2s;
    box-sizing: border-box;
}
.nd-login-field input:focus {
    outline: none;
    border-color: #518889;
    box-shadow: 0 0 0 3px rgba(81,136,137,0.12);
    background: #fff;
}
.nd-login-remember {
    display: flex;
    align-items: center;
    gap: 8px;
    margin: 4px 0 8px;
    font-size: 13px;
    color: #666;
}
.nd-login-remember input[type="checkbox"] {
    accent-color: #518889;
}

/* Submit button */
.nd-login-submit {
    width: 100%;
    padding: 14px;
    background: #518889;
    color: #fff;
    border: none;
    border-radius: 10px;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s, transform 0.1s;
    margin-top: 8px;
}
.nd-login-submit:hover {
    background: #3d6b6c;
}
.nd-login-submit:active {
    transform: scale(0.98);
}

/* Links */
.nd-login-links {
    display: flex;
    justify-content: space-between;
    margin-top: 16px;
    font-size: 13px;
}
.nd-login-links a {
    color: #518889;
    text-decoration: none;
}
.nd-login-links a:hover {
    text-decoration: underline;
}

/* Divider */
.nd-login-divider {
    position: relative;
    text-align: center;
    margin: 24px 0;
}
.nd-login-divider::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    border-top: 1px solid #e5e5e5;
}
.nd-login-divider span {
    position: relative;
    background: #fff;
    padding: 0 16px;
    color: #aaa;
    font-size: 13px;
}

/* Google button */
.nd-google-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    width: 100%;
    padding: 13px 20px;
    background: #fff;
    border: 1.5px solid #dadce0;
    border-radius: 10px;
    color: #3c4043;
    font-size: 15px;
    font-weight: 500;
    text-decoration: none;
    transition: background 0.2s, box-shadow 0.2s;
    cursor: pointer;
}
.nd-google-btn:hover {
    background: #f7f8f8;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
}

/* Error message */
.nd-login-error {
    background: #fef2f2;
    border: 1px solid #fecaca;
    border-radius: 10px;
    padding: 12px 14px;
    color: #dc2626;
    font-size: 13px;
    margin-bottom: 16px;
}

/* Register CTA */
.nd-login-register {
    text-align: center;
    margin-top: 24px;
    font-size: 14px;
    color: #888;
}
.nd-login-register a {
    color: #518889;
    font-weight: 600;
    text-decoration: none;
}
.nd-login-register a:hover {
    text-decoration: underline;
}

/* LINE plugin button — restyle to match Google button */
.ec-off2Grid__cell .btn { margin: 0 !important; }
.ec-off2Grid__cell .line-button { display: block; }
.ec-off2Grid__cell .line-button img {
    display: none !important;
}
.ec-off2Grid__cell .btn a.line-button {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    width: 100%;
    padding: 13px 20px;
    background: #06c755;
    border: none;
    border-radius: 10px;
    color: #fff;
    font-size: 15px;
    font-weight: 500;
    text-decoration: none;
    transition: background 0.2s;
    cursor: pointer;
}
.ec-off2Grid__cell .btn a.line-button::before {
    content: '';
    display: inline-block;
    width: 22px;
    height: 22px;
    background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="white"><path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.627-.63h2.386c.349 0 .63.285.63.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.627-.63.349 0 .631.285.631.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.282.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/></svg>') no-repeat center / contain;
    flex-shrink: 0;
}
.ec-off2Grid__cell .btn a.line-button::after {
    content: 'LINEでログイン';
}
.ec-off2Grid__cell .btn a.line-button:hover {
    background: #05b34c;
}
.nd-social-buttons {
    display: flex;
    flex-direction: column;
    gap: 10px;
}

@media (max-width: 480px) {
    .nd-login-wrap { margin: 20px auto 40px; }
    .nd-login-card { padding: 28px 20px 24px; border-radius: 12px; }
}
</style>
{% endblock %}

{% block main %}
<div class="nd-login-wrap">
    <div class="nd-login-card">
        <div class="nd-login-header">
            <div class="nd-login-icon">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                </svg>
            </div>
            <h1>{{ 'ログイン'|trans }}</h1>
            <p>アカウントにログインしてください</p>
        </div>

        {# ── Social Login buttons ── #}
        {# ec-off2Grid__cell is required for LINE plugin to inject its button #}
        <div class="ec-off2Grid__cell">
            <a href="{{ url('google_login') }}" class="nd-google-btn">
                <svg width="20" height="20" viewBox="0 0 48 48"><path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/><path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/><path fill="#34A853" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/><path fill="#FBBC05" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/></svg>
                Googleでログイン
            </a>
            {# LINE plugin will auto-insert its button here #}
        </div>

        <div class="nd-login-divider"><span>または</span></div>

        {# ── Email/Password Login ── #}
        <form name="login_mypage" id="login_mypage" method="post" action="{{ url('mypage_login') }}">
            {% if app.session.flashBag.has('eccube.login.target.path') %}
                {% for targetPath in app.session.flashBag.peek('eccube.login.target.path') %}
                    <input type="hidden" name="_target_path" value="{{ targetPath }}" />
                {% endfor %}
            {% endif %}

            {% if error %}
                <div class="nd-login-error">
                    {{ error.messageKey|trans(error.messageData, 'validators')|nl2br }}
                </div>
            {% endif %}

            {% for reset_complete in app.session.flashbag.get('password_reset_complete') %}
                <div class="nd-login-error" style="background:#f0fdf4; border-color:#bbf7d0; color:#16a34a;">
                    {{ reset_complete|trans }}
                </div>
            {% endfor %}

            <div class="nd-login-field">
                <label for="login_email">メールアドレス</label>
                {{ form_widget(form.login_email, {'attr': {'style': 'ime-mode:disabled;', 'placeholder': 'example@email.com', 'autofocus': true}}) }}
            </div>

            <div class="nd-login-field">
                <label for="login_pass">パスワード</label>
                {{ form_widget(form.login_pass, {'attr': {'placeholder': 'パスワードを入力'}}) }}
            </div>

            {% if BaseInfo.option_remember_me %}
            <div class="nd-login-remember">
                {% if is_granted('IS_AUTHENTICATED_REMEMBERED') %}
                    <input type="hidden" name="login_memory" value="1">
                {% else %}
                    {{ form_widget(form.login_memory, { 'label': '次回から自動的にログインする'|trans }) }}
                {% endif %}
            </div>
            {% endif %}

            <button type="submit" class="nd-login-submit">{{ 'ログイン'|trans }}</button>

            <div class="nd-login-links">
                <a href="{{ url('forgot') }}">パスワードをお忘れですか？</a>
            </div>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
        </form>
    </div>

    <div class="nd-login-register">
        アカウントをお持ちでないですか？ <a href="{{ url('entry') }}">新規会員登録</a>
    </div>
</div>
{% endblock %}
