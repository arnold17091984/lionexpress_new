<style>
/* ========================================================
   Campaign: Referral  –  nd-campaign-* scoped styles
   ======================================================== */
:root {
    --brand-primary: #518889;
    --brand-dark: #3d6a6b;
    --brand-pale: #e8f4f4;
    --neutral-900: #111;
    --neutral-600: #4b5563;
    --white: #fff;
}

/* --- breadcrumb --- */
.nd-campaign-breadcrumb {
    max-width: 1100px;
    margin: 0 auto;
    padding: 1.2rem 2rem;
    font-size: 1.2rem;
    color: var(--neutral-600);
}
.nd-campaign-breadcrumb a {
    color: var(--brand-primary);
    text-decoration: none;
}
.nd-campaign-breadcrumb a:hover {
    text-decoration: underline;
}
.nd-campaign-breadcrumb span {
    margin: 0 0.6rem;
}

/* --- hero --- */
.nd-campaign-hero {
    background: linear-gradient(135deg, var(--brand-primary) 0%, var(--brand-dark) 100%);
    color: var(--white);
    text-align: center;
    padding: 6rem 2rem 5rem;
    border-radius: 0 0 2.4rem 2.4rem;
}
.nd-campaign-hero__badge {
    display: inline-block;
    background: rgba(255,255,255,0.2);
    color: var(--white);
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    padding: 0.4rem 1.6rem;
    border-radius: 100px;
    margin-bottom: 2rem;
}
.nd-campaign-hero__title {
    font-size: 3.2rem;
    font-weight: 800;
    line-height: 1.4;
    margin: 0 0 1.6rem;
}
.nd-campaign-hero__sub {
    font-size: 1.6rem;
    opacity: 0.9;
    margin: 0;
}

/* --- section --- */
.nd-campaign-section {
    max-width: 900px;
    margin: 0 auto;
    padding: 6rem 2rem;
}
.nd-campaign-section__title {
    font-size: 2.4rem;
    font-weight: 700;
    color: var(--neutral-900);
    text-align: center;
    margin: 0 0 4rem;
    position: relative;
}
.nd-campaign-section__title::after {
    content: '';
    display: block;
    width: 4rem;
    height: 0.3rem;
    background: var(--brand-primary);
    border-radius: 2px;
    margin: 1.2rem auto 0;
}

/* --- point illustration --- */
.nd-campaign-points {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 2.4rem;
    flex-wrap: wrap;
    margin-bottom: 6rem;
}
.nd-campaign-points__card {
    flex: 0 1 26rem;
    background: var(--white);
    border: 2px solid var(--brand-primary);
    border-radius: 1.6rem;
    padding: 3.2rem 2.4rem;
    text-align: center;
}
.nd-campaign-points__icon {
    width: 5.6rem;
    height: 5.6rem;
    color: var(--brand-primary);
    margin-bottom: 1.6rem;
}
.nd-campaign-points__label {
    font-size: 1.4rem;
    color: var(--neutral-600);
    margin: 0 0 0.8rem;
}
.nd-campaign-points__value {
    font-size: 3.6rem;
    font-weight: 800;
    color: var(--brand-primary);
    margin: 0;
}
.nd-campaign-points__value span {
    font-size: 1.8rem;
    font-weight: 600;
}
.nd-campaign-points__plus {
    font-size: 3.2rem;
    font-weight: 700;
    color: var(--brand-primary);
}

/* --- steps --- */
.nd-campaign-steps {
    display: flex;
    justify-content: center;
    align-items: flex-start;
    gap: 1.6rem;
    flex-wrap: wrap;
}
.nd-campaign-step {
    flex: 0 1 22rem;
    background: var(--white);
    border: 1px solid #e5e7eb;
    border-radius: 1.6rem;
    padding: 3.2rem 2.4rem;
    text-align: center;
}
.nd-campaign-step__number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 4.4rem;
    height: 4.4rem;
    border-radius: 50%;
    background: var(--brand-primary);
    color: var(--white);
    font-size: 1.8rem;
    font-weight: 700;
    margin-bottom: 1.6rem;
}
.nd-campaign-step__icon {
    width: 4.8rem;
    height: 4.8rem;
    margin-bottom: 1.2rem;
    color: var(--brand-primary);
}
.nd-campaign-step__label {
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--neutral-900);
    margin: 0 0 0.8rem;
}
.nd-campaign-step__desc {
    font-size: 1.3rem;
    color: var(--neutral-600);
    margin: 0;
    line-height: 1.6;
}
.nd-campaign-arrow {
    display: flex;
    align-items: center;
    padding-top: 4rem;
    color: var(--brand-primary);
}
.nd-campaign-arrow svg {
    width: 2.4rem;
    height: 2.4rem;
}

/* --- conditions --- */
.nd-campaign-conditions {
    background: var(--brand-pale);
    border-radius: 1.6rem;
    padding: 4rem 3.2rem;
    max-width: 760px;
    margin: 0 auto;
}
.nd-campaign-conditions__title {
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--neutral-900);
    margin: 0 0 2rem;
    display: flex;
    align-items: center;
    gap: 0.8rem;
}
.nd-campaign-conditions__title svg {
    width: 2.4rem;
    height: 2.4rem;
    color: var(--brand-primary);
}
.nd-campaign-conditions__list {
    list-style: none;
    padding: 0;
    margin: 0;
}
.nd-campaign-conditions__list li {
    position: relative;
    padding: 0.8rem 0 0.8rem 2.4rem;
    font-size: 1.4rem;
    color: var(--neutral-600);
    line-height: 1.7;
}
.nd-campaign-conditions__list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 1.4rem;
    width: 0.6rem;
    height: 0.6rem;
    border-radius: 50%;
    background: var(--brand-primary);
}

/* --- CTA --- */
.nd-campaign-cta {
    text-align: center;
    padding: 5rem 2rem;
}
.nd-campaign-cta__btn {
    display: inline-block;
    background: var(--brand-primary);
    color: var(--white);
    font-size: 1.8rem;
    font-weight: 700;
    padding: 1.8rem 4.8rem;
    border-radius: 100px;
    text-decoration: none;
    transition: background 0.2s, transform 0.2s;
    box-shadow: 0 4px 16px rgba(81,136,137,0.25);
}
.nd-campaign-cta__btn:hover {
    background: var(--brand-dark);
    transform: translateY(-2px);
}
.nd-campaign-cta__note {
    margin-top: 1.6rem;
    font-size: 1.3rem;
    color: var(--neutral-600);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
}
.nd-campaign-cta__note svg {
    width: 1.6rem;
    height: 1.6rem;
    color: var(--brand-primary);
}

/* --- responsive --- */
@media (max-width: 767px) {
    .nd-campaign-hero { padding: 4rem 1.6rem 3.6rem; border-radius: 0 0 1.6rem 1.6rem; }
    .nd-campaign-hero__title { font-size: 2.2rem; }
    .nd-campaign-hero__sub { font-size: 1.4rem; }
    .nd-campaign-steps { flex-direction: column; align-items: center; }
    .nd-campaign-arrow { padding-top: 0; transform: rotate(90deg); }
    .nd-campaign-step { flex: 0 1 100%; max-width: 32rem; }
    .nd-campaign-points { flex-direction: column; align-items: center; }
    .nd-campaign-points__plus { transform: rotate(90deg); }
    .nd-campaign-points__card { flex: 0 1 100%; max-width: 32rem; }
    .nd-campaign-section { padding: 4rem 1.6rem; }
    .nd-campaign-section__title { font-size: 2rem; }
    .nd-campaign-conditions { padding: 3.2rem 2rem; }
    .nd-campaign-cta__btn { font-size: 1.6rem; padding: 1.6rem 3.2rem; }
}
</style>
