{% extends 'default_frame.twig' %}

{% set body_class = 'page_campaign_ranking' %}

{% block stylesheet %}
<style>
/* ========================================================
   Campaign: Ranking  –  nd-campaign-* scoped styles
   ======================================================== */
:root {
    --brand-primary: #518889;
    --brand-dark: #3d6a6b;
    --brand-pale: #e8f4f4;
    --neutral-900: #111;
    --neutral-600: #4b5563;
    --neutral-200: #e5e7eb;
    --white: #fff;
}

/* --- breadcrumb --- */
.nd-campaign-breadcrumb {
    max-width: 1100px;
    margin: 0 auto;
    padding: 1.2rem 2rem;
    font-size: 1.2rem;
    color: var(--neutral-600);
}
.nd-campaign-breadcrumb a {
    color: var(--brand-primary);
    text-decoration: none;
}
.nd-campaign-breadcrumb a:hover {
    text-decoration: underline;
}
.nd-campaign-breadcrumb span {
    margin: 0 0.6rem;
}

/* --- hero --- */
.nd-campaign-hero {
    background: linear-gradient(135deg, var(--brand-primary) 0%, var(--brand-dark) 100%);
    color: var(--white);
    text-align: center;
    padding: 6rem 2rem 5rem;
    border-radius: 0 0 2.4rem 2.4rem;
}
.nd-campaign-hero__badge {
    display: inline-block;
    background: rgba(255,255,255,0.2);
    color: var(--white);
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    padding: 0.4rem 1.6rem;
    border-radius: 100px;
    margin-bottom: 2rem;
}
.nd-campaign-hero__title {
    font-size: 3.2rem;
    font-weight: 800;
    line-height: 1.4;
    margin: 0 0 1.6rem;
}
.nd-campaign-hero__sub {
    font-size: 1.6rem;
    opacity: 0.9;
    margin: 0;
}

/* --- section --- */
.nd-campaign-section {
    max-width: 1000px;
    margin: 0 auto;
    padding: 6rem 2rem;
}
.nd-campaign-section__title {
    font-size: 2.4rem;
    font-weight: 700;
    color: var(--neutral-900);
    text-align: center;
    margin: 0 0 4rem;
    position: relative;
}
.nd-campaign-section__title::after {
    content: '';
    display: block;
    width: 4rem;
    height: 0.3rem;
    background: var(--brand-primary);
    border-radius: 2px;
    margin: 1.2rem auto 0;
}

/* --- category tabs --- */
.nd-campaign-tabs {
    display: flex;
    justify-content: center;
    gap: 0.8rem;
    flex-wrap: wrap;
    margin-bottom: 4rem;
}
.nd-campaign-tab {
    display: inline-block;
    padding: 1rem 2.4rem;
    font-size: 1.4rem;
    font-weight: 600;
    color: var(--neutral-600);
    background: var(--white);
    border: 1px solid var(--neutral-200);
    border-radius: 100px;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.2s;
}
.nd-campaign-tab:hover,
.nd-campaign-tab.is-active {
    background: var(--brand-primary);
    color: var(--white);
    border-color: var(--brand-primary);
}

/* --- category sections --- */
.nd-campaign-category {
    margin-bottom: 5rem;
}
.nd-campaign-category__header {
    display: flex;
    align-items: center;
    gap: 1.2rem;
    margin-bottom: 2.4rem;
    padding-bottom: 1.6rem;
    border-bottom: 2px solid var(--brand-primary);
}
.nd-campaign-category__icon {
    width: 3.6rem;
    height: 3.6rem;
    color: var(--brand-primary);
    flex-shrink: 0;
}
.nd-campaign-category__name {
    font-size: 2rem;
    font-weight: 700;
    color: var(--neutral-900);
    margin: 0;
}
.nd-campaign-category__desc {
    font-size: 1.4rem;
    color: var(--neutral-600);
    line-height: 1.7;
    margin: 0 0 2.4rem;
}

/* --- ranking placeholder --- */
.nd-campaign-ranking-placeholder {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    margin-bottom: 2.4rem;
}
.nd-campaign-ranking-item {
    background: var(--white);
    border: 1px solid var(--neutral-200);
    border-radius: 1.2rem;
    padding: 2.4rem;
    text-align: center;
    position: relative;
}
.nd-campaign-ranking-item__rank {
    position: absolute;
    top: -0.8rem;
    left: 1.6rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3.2rem;
    height: 3.2rem;
    border-radius: 50%;
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--white);
}
.nd-campaign-ranking-item__rank--1 { background: #d4a017; }
.nd-campaign-ranking-item__rank--2 { background: #9ca3af; }
.nd-campaign-ranking-item__rank--3 { background: #b87333; }
.nd-campaign-ranking-item__img {
    width: 100%;
    aspect-ratio: 1;
    background: var(--brand-pale);
    border-radius: 0.8rem;
    margin-bottom: 1.2rem;
    display: flex;
    align-items: center;
    justify-content: center;
}
.nd-campaign-ranking-item__img svg {
    width: 4rem;
    height: 4rem;
    color: var(--brand-primary);
    opacity: 0.4;
}
.nd-campaign-ranking-item__name {
    font-size: 1.4rem;
    font-weight: 600;
    color: var(--neutral-900);
    margin: 0 0 0.4rem;
}
.nd-campaign-ranking-item__info {
    font-size: 1.2rem;
    color: var(--neutral-600);
    margin: 0;
}

/* --- browse CTA --- */
.nd-campaign-category__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--brand-primary);
    text-decoration: none;
    padding: 1.2rem 2.4rem;
    border: 2px solid var(--brand-primary);
    border-radius: 100px;
    transition: all 0.2s;
}
.nd-campaign-category__cta:hover {
    background: var(--brand-primary);
    color: var(--white);
}
.nd-campaign-category__cta svg {
    width: 1.8rem;
    height: 1.8rem;
}

/* --- bottom note --- */
.nd-campaign-note {
    text-align: center;
    font-size: 1.3rem;
    color: var(--neutral-600);
    padding: 2rem 2rem 0;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
}
.nd-campaign-note svg {
    width: 1.6rem;
    height: 1.6rem;
    color: var(--brand-primary);
    flex-shrink: 0;
}

/* --- main CTA --- */
.nd-campaign-cta {
    text-align: center;
    padding: 4rem 2rem 6rem;
}
.nd-campaign-cta__btn {
    display: inline-block;
    background: var(--brand-primary);
    color: var(--white);
    font-size: 1.8rem;
    font-weight: 700;
    padding: 1.8rem 4.8rem;
    border-radius: 100px;
    text-decoration: none;
    transition: background 0.2s, transform 0.2s;
    box-shadow: 0 4px 16px rgba(81,136,137,0.25);
}
.nd-campaign-cta__btn:hover {
    background: var(--brand-dark);
    transform: translateY(-2px);
}

/* --- responsive --- */
@media (max-width: 767px) {
    .nd-campaign-hero { padding: 4rem 1.6rem 3.6rem; border-radius: 0 0 1.6rem 1.6rem; }
    .nd-campaign-hero__title { font-size: 2.4rem; }
    .nd-campaign-hero__sub { font-size: 1.4rem; }
    .nd-campaign-section { padding: 4rem 1.6rem; }
    .nd-campaign-section__title { font-size: 2rem; }
    .nd-campaign-tabs { gap: 0.6rem; }
    .nd-campaign-tab { padding: 0.8rem 1.6rem; font-size: 1.3rem; }
    .nd-campaign-ranking-placeholder { grid-template-columns: repeat(2, 1fr); }
    .nd-campaign-category__name { font-size: 1.8rem; }
    .nd-campaign-cta__btn { font-size: 1.6rem; padding: 1.6rem 3.2rem; }
}
</style>
{% endblock %}

