<style>
/* ========================================================
   Campaign: Register  –  nd-campaign-* scoped styles
   ======================================================== */
:root {
    --brand-primary: #518889;
    --brand-dark: #3d6a6b;
    --brand-pale: #e8f4f4;
    --neutral-900: #111;
    --neutral-600: #4b5563;
    --white: #fff;
}

/* --- breadcrumb --- */
.nd-campaign-breadcrumb {
    max-width: 1100px;
    margin: 0 auto;
    padding: 1.2rem 2rem;
    font-size: 1.2rem;
    color: var(--neutral-600);
}
.nd-campaign-breadcrumb a {
    color: var(--brand-primary);
    text-decoration: none;
}
.nd-campaign-breadcrumb a:hover {
    text-decoration: underline;
}
.nd-campaign-breadcrumb span {
    margin: 0 0.6rem;
}

/* --- hero --- */
.nd-campaign-hero {
    background: linear-gradient(135deg, var(--brand-primary) 0%, var(--brand-dark) 100%);
    color: var(--white);
    text-align: center;
    padding: 6rem 2rem 5rem;
    border-radius: 0 0 2.4rem 2.4rem;
}
.nd-campaign-hero__badge {
    display: inline-block;
    background: rgba(255,255,255,0.2);
    color: var(--white);
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    padding: 0.4rem 1.6rem;
    border-radius: 100px;
    margin-bottom: 2rem;
}
.nd-campaign-hero__title {
    font-size: 3.2rem;
    font-weight: 800;
    line-height: 1.4;
    margin: 0 0 1.6rem;
}
.nd-campaign-hero__sub {
    font-size: 1.6rem;
    opacity: 0.9;
    margin: 0;
}

/* --- section wrapper --- */
.nd-campaign-section {
    max-width: 900px;
    margin: 0 auto;
    padding: 6rem 2rem;
}
.nd-campaign-section__title {
    font-size: 2.4rem;
    font-weight: 700;
    color: var(--neutral-900);
    text-align: center;
    margin: 0 0 4rem;
    position: relative;
}
.nd-campaign-section__title::after {
    content: '';
    display: block;
    width: 4rem;
    height: 0.3rem;
    background: var(--brand-primary);
    border-radius: 2px;
    margin: 1.2rem auto 0;
}

/* --- steps --- */
.nd-campaign-steps {
    display: flex;
    justify-content: center;
    align-items: flex-start;
    gap: 1.6rem;
    flex-wrap: wrap;
}
.nd-campaign-step {
    flex: 0 1 22rem;
    background: var(--white);
    border: 1px solid #e5e7eb;
    border-radius: 1.6rem;
    padding: 3.2rem 2.4rem;
    text-align: center;
    position: relative;
}
.nd-campaign-step__number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 4.4rem;
    height: 4.4rem;
    border-radius: 50%;
    background: var(--brand-primary);
    color: var(--white);
    font-size: 1.8rem;
    font-weight: 700;
    margin-bottom: 1.6rem;
}
.nd-campaign-step__label {
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--neutral-900);
    margin: 0 0 0.8rem;
}
.nd-campaign-step__desc {
    font-size: 1.3rem;
    color: var(--neutral-600);
    margin: 0;
    line-height: 1.6;
}
.nd-campaign-step__icon {
    width: 4.8rem;
    height: 4.8rem;
    margin-bottom: 1.2rem;
    color: var(--brand-primary);
}
.nd-campaign-arrow {
    display: flex;
    align-items: center;
    padding-top: 4rem;
    color: var(--brand-primary);
}
.nd-campaign-arrow svg {
    width: 2.4rem;
    height: 2.4rem;
}

/* --- benefits grid --- */
.nd-campaign-benefits {
    background: var(--brand-pale);
    border-radius: 1.6rem;
    padding: 4.8rem 3.2rem;
}
.nd-campaign-benefits__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2.4rem;
    margin-top: 3.2rem;
}
.nd-campaign-benefit {
    display: flex;
    align-items: flex-start;
    gap: 1.6rem;
    background: var(--white);
    border-radius: 1.2rem;
    padding: 2.4rem;
}
.nd-campaign-benefit__icon {
    flex-shrink: 0;
    width: 4rem;
    height: 4rem;
    color: var(--brand-primary);
}
.nd-campaign-benefit__title {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--neutral-900);
    margin: 0 0 0.4rem;
}
.nd-campaign-benefit__text {
    font-size: 1.3rem;
    color: var(--neutral-600);
    margin: 0;
    line-height: 1.6;
}

/* --- CTA --- */
.nd-campaign-cta {
    text-align: center;
    padding: 5rem 2rem;
}
.nd-campaign-cta__btn {
    display: inline-block;
    background: var(--brand-primary);
    color: var(--white);
    font-size: 1.8rem;
    font-weight: 700;
    padding: 1.8rem 4.8rem;
    border-radius: 100px;
    text-decoration: none;
    transition: background 0.2s, transform 0.2s;
    box-shadow: 0 4px 16px rgba(81,136,137,0.25);
}
.nd-campaign-cta__btn:hover {
    background: var(--brand-dark);
    transform: translateY(-2px);
}

/* --- trust --- */
.nd-campaign-trust {
    display: flex;
    justify-content: center;
    gap: 3.2rem;
    margin-top: 2.4rem;
    flex-wrap: wrap;
}
.nd-campaign-trust__item {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    font-size: 1.3rem;
    color: var(--neutral-600);
}
.nd-campaign-trust__item svg {
    width: 2rem;
    height: 2rem;
    color: var(--brand-primary);
}

/* --- FAQ --- */
.nd-campaign-faq {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 2rem 6rem;
}
.nd-campaign-faq__item {
    border-bottom: 1px solid #e5e7eb;
}
.nd-campaign-faq__q {
    display: flex;
    align-items: center;
    gap: 1.2rem;
    width: 100%;
    padding: 2rem 0;
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--neutral-900);
    cursor: pointer;
    list-style: none;
}
.nd-campaign-faq__q::-webkit-details-marker { display: none; }
.nd-campaign-faq__q-badge {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.8rem;
    height: 2.8rem;
    border-radius: 50%;
    background: var(--brand-primary);
    color: var(--white);
    font-size: 1.2rem;
    font-weight: 700;
}
.nd-campaign-faq__chevron {
    margin-left: auto;
    transition: transform 0.25s;
}
.nd-campaign-faq__chevron svg {
    width: 1.6rem;
    height: 1.6rem;
    color: var(--neutral-600);
}
.nd-campaign-faq__item[open] .nd-campaign-faq__chevron {
    transform: rotate(180deg);
}
.nd-campaign-faq__a {
    padding: 0 0 2rem 4rem;
    font-size: 1.4rem;
    color: var(--neutral-600);
    line-height: 1.8;
}

/* --- responsive --- */
@media (max-width: 767px) {
    .nd-campaign-hero { padding: 4rem 1.6rem 3.6rem; border-radius: 0 0 1.6rem 1.6rem; }
    .nd-campaign-hero__title { font-size: 2.4rem; }
    .nd-campaign-hero__sub { font-size: 1.4rem; }
    .nd-campaign-steps { flex-direction: column; align-items: center; }
    .nd-campaign-arrow { padding-top: 0; transform: rotate(90deg); }
    .nd-campaign-step { flex: 0 1 100%; max-width: 32rem; }
    .nd-campaign-benefits__grid { grid-template-columns: 1fr; }
    .nd-campaign-section { padding: 4rem 1.6rem; }
    .nd-campaign-section__title { font-size: 2rem; }
    .nd-campaign-cta__btn { font-size: 1.6rem; padding: 1.6rem 3.2rem; }
    .nd-campaign-trust { gap: 1.6rem; }
    .nd-campaign-faq__a { padding-left: 0; }
}
</style>
