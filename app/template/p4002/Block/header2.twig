{# Styles moved to theme SCSS: _11.2.header.scss #}

<div class="header2">
    {# ロゴ #}
    {{ include('Block/logo.twig') }}
    {# 電話番号 
    <a class="header-tel pc-only" href="tel:05037035539">
        <img src="{{ asset('assets/img/common/クスリス電話番号.jpg', 'user_data') }}" alt="電話番号">
    </a>
    #}
    {# アイコン — SVGインライン統一 #}
    <ul class="icon-items">
        <li class="icon-item nd-icon-line">
            <a href="https://line.me/R/ti/p/@229ulhco" rel="noopener noreferrer">
                <img class="nd-header-icon nd-header-icon--line" src="{{ asset('assets/img/common/LINE.png', 'user_data') }}" alt="" width="24" height="24">
                <span class="nd-header-icon-label">LINE</span>
            </a>
        </li>
        <li class="icon-item">
            <a href="mailto:info@lion-express.com">
                <svg class="nd-header-icon" width="24" height="24" viewBox="0 0 24 24" fill="var(--neutral-500)" stroke="none" aria-hidden="true"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
                <span class="nd-header-icon-label">メール</span>
            </a>
        </li>
        <li class="icon-item pc-only">
            {% if is_granted('ROLE_USER') %}
                <a href="{{ url('mypage') }}">
                    <svg class="nd-header-icon" width="24" height="24" viewBox="0 0 24 24" fill="var(--neutral-500)" stroke="none" aria-hidden="true"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z"/></svg>
                    <span class="nd-header-icon-label">マイページ</span>
                </a>
            {% else %}
                <a href="{{ url('mypage_login') }}">
                    <svg class="nd-header-icon" width="24" height="24" viewBox="0 0 24 24" fill="var(--neutral-500)" stroke="none" aria-hidden="true"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z"/></svg>
                    <span class="nd-header-icon-label">ログイン</span>
                </a>
            {% endif %}
        </li>
    </ul>
    {# カート #}
    <div class="ec-headerRole__cart ec-headerCart">
        {{ include('Block/cart.twig') }}
    </div>
</div>