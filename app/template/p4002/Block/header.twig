<script>
$(function() {
    // ハンバーガーメニューのクリックイベント
    $('.ec-headerHamburger').on('click', function() {
        $(this).toggleClass('is-active');
        // ドロワーメニューを表示
        $('.ec-drawerRole').toggleClass('is-active');
        $('.ec-drawerOverlay').toggleClass('is-active'); // ここを変更
        $('body').toggleClass('have-fixed');
    });
});
</script>