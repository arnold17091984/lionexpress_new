        <span class="ec-headerHamburger__line"></span>
        <span class="ec-headerHamburger__line"></span>
    </button>
    
    <header class="ec-header" id="header">
        {{ include('Block/header2.twig') }}
        {{ render(path('block_sp_search')) }}
        <nav class="ec-headerNavigation ec-headerNavigation_media_pc" aria-label="メインナビゲーション">
