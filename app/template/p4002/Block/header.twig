{# Styles moved to theme SCSS: _11.2.header.scss #}
{% set Categories = repository('Eccube\\Entity\\Category').getList() %}
{% macro tree(Category) %}
  {% from _self import tree %}
  <a href="{{ url('product_list', {'category_id': Category.id}) }}">
    {{ Category.name }}
  </a>
  {% if Category.children|length %}
    <ul>
      {% for ChildCategory in Category.children %}
        <li>
          {{ tree(ChildCategory) }}
        </li>
      {% endfor %}
    </ul>
  {% endif %}
{% endmacro %}
{% from _self import tree %}
<div class="ec-headerNaviRole">
    <!-- ハンバーガーメニュー追加 -->
    <button class="ec-headerHamburger" type="button" aria-expanded="false" aria-label="メニュー" aria-controls="ec-drawer-menu">
