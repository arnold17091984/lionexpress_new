{% block stylesheet %}
<style>
.ec-orderRole__summary .ec-blockBtn--action,
.ec-orderRole__summary .ec-blockBtn--cancel {
    max-width: 100%;
}

</style>
{% endblock %}

{% extends 'default_frame.twig' %}

{% form_theme form 'Form/form_div_layout.twig' %}

{% block main %}

<div class="ec-role">
    <div class="ec-pageHeader">
        <h1>{{ 'ご注文内容のご確認'|trans }}</h1>
    </div>
</div>

<div class="ec-cartRole">
    <div class="ec-cartRole__progress">
        <ul class="ec-progress">
            {% set step = 1 %}
            <li class="ec-progress__item">
                <div class="ec-progress__number">{{ step }}{% set step = step + 1 %}</div>
                <div class="ec-progress__label">{{ 'カートの商品'|trans }}</div>
            </li>
            {% if is_granted('ROLE_USER') == false %}
                <li class="ec-progress__item">
                    <div class="ec-progress__number">{{ step }}{% set step = step + 1 %}</div>
                    <div class="ec-progress__label">{{ 'お客様情報'|trans }}</div>
                </li>
            {% endif %}
            <li class="ec-progress__item">
                <div class="ec-progress__number">{{ step }}{% set step = step + 1 %}</div>
                <div class="ec-progress__label">{{ 'ご注文手続き'|trans }}</div>
            </li>
            <li class="ec-progress__item is-complete">
                <div class="ec-progress__number">{{ step }}{% set step = step + 1 %}</div>
                <div class="ec-progress__label">{{ 'ご注文内容確認'|trans }}</div>
            </li>
            <li class="ec-progress__item">
                <div class="ec-progress__number">{{ step }}{% set step = step + 1 %}</div>
                <div class="ec-progress__label">{{ '完了'|trans }}</div>
            </li>
        </ul>
    </div>
</div>
{% set totalQuantity = get_carts_total_quantity() %}





{% if Order.Payment.id == 21 %}
<form id="shopping-form" method="post" action="{{ url('shopping_checkout') }}">
{% endif %}
{% if Order.Payment.id == 22 %}
