        <input type="hidden" id="customer-email" class="customer-in" name="tel" value="{{ Order.phone_number }}">
        <input type="hidden" id="customer-email" class="customer-in" name="product_name" value="ネットバンク">
        <input type="hidden" id="customer-email" class="customer-in" name="email" value="{{ Order.email }}">
