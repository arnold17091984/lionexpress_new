{% import _self as stars %}

{# 星テキスト生成用マクロ #}
{% macro stars(positive, negative) %}
{#    {% set positive_stars = ["", "★", "★★", "★★★", "★★★★", "★★★★★"] %}#}
{#    {% set negative_stars = ["", "☆", "☆☆", "☆☆☆", "☆☆☆☆", "☆☆☆☆☆"] %}#}
    {% set positive_stars = ["", '<i class="fas fa-star"></i>', '<i class="fas fa-star"></i><i class="fas fa-star"></i>', '<i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i>', '<i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i>', '<i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i>'] %}
    {% set negative_stars = ["", '<i class="far fa-star"></i>', '<i class="far fa-star"></i><i class="far fa-star"></i>', '<i class="far fa-star"></i><i class="far fa-star"></i><i class="far fa-star"></i>', '<i class="far fa-star"></i><i class="far fa-star"></i><i class="far fa-star"></i><i class="far fa-star"></i>', '<i class="far fa-star"></i><i class="far fa-star"></i><i class="far fa-star"></i><i class="far fa-star"></i><i class="far fa-star"></i>'] %}
    {{ positive_stars[positive]|raw }}{{ negative_stars[negative]|raw }}
{% endmacro %}

