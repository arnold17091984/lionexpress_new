{% block stylesheet %}
<style>
@media only screen and (max-width: 1023px) {
    .ec-blockBtn--action,
    .ec-blockBtn--cancel {
        max-width: 100%;
        margin-bottom: 100px;
    }
}
</style>
{% endblock %}

{% extends 'default_frame.twig' %}

{% set body_class = 'registration_page' %}

{% block main %}
    <div class="ec-role">
        <div class="ec-pageHeader">
            <h1>{{ '新規会員登録(仮登録完了)'|trans }}</h1>
        </div>
    </div>
    <div class="ec-registerCompleteRole">
        <div class="ec-off3Grid ec-text-ac">
            <div class="ec-off3Grid__cell">
                <div class="ec-reportHeading">
                    <h2>{{ '会員登録ありがとうございます'|trans }}</h2>
                </div>
                <p class="ec-reportDescription">{{ '現在は未だ「仮会員」の状態です。
				ご入力いただいたメールアドレス宛に、ご本人様確認用のメールをお送りいたしましたので、メール本文内の確認URLをクリックいただくと、本会員登録が完了となります。
				ご確認くださいますようお願いします。
'|trans|nl2br }}</p>
                <div class="ec-off4Grid">
                    <div class="ec-off4Grid__cell"><a class="ec-blockBtn--cancel" href="{{ url('homepage') }}">{{ 'トップページへ'|trans }}</a></div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}